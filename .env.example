# ==============================================================================
# y-agent Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# ==============================================================================

# --- LLM Provider -----------------------------------------------------------
# API key for your LLM provider (OpenAI, Anthropic, etc.)
Y_PROVIDER_API_KEY=sk-your-api-key-here

# --- Application Ports -------------------------------------------------------
Y_AGENT_PORT=8080

# --- PostgreSQL (Diagnostics & Analytics) ------------------------------------
POSTGRES_USER=yagent
POSTGRES_PASSWORD=yagent
POSTGRES_DB=yagent_diagnostics
POSTGRES_PORT=5432

# --- Qdrant (Vector Store) ---------------------------------------------------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Logging -----------------------------------------------------------------
# Levels: error, warn, info, debug, trace
RUST_LOG=info
