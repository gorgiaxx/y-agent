# =============================================================================
# Dockerfile for building y-agent AppImage on Linux
#
# Usage:
#   docker build -t y-agent-appimage-builder -f Dockerfile.appimage .
#   docker run --rm -v "$(pwd)/dist:/output" y-agent-appimage-builder
# =============================================================================
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# -- System dependencies for Tauri v2 on Linux ---------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    curl \
    file \
    libssl-dev \
    pkg-config \
    libwebkit2gtk-4.1-dev \
    libayatana-appindicator3-dev \
    librsvg2-dev \
    patchelf \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# -- Install Rust (pinned to project toolchain) --------------------------------
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain 1.94.0
ENV PATH="/root/.cargo/bin:${PATH}"

# -- Install Node.js 22 LTS ---------------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# -- Install appimagetool ------------------------------------------------------
RUN ARCH=$(uname -m) && \
    case "$ARCH" in \
      x86_64|amd64) APPIMAGE_ARCH="x86_64" ;; \
      aarch64|arm64) APPIMAGE_ARCH="aarch64" ;; \
    esac && \
    curl -fsSL "https://github.com/AppImage/appimagetool/releases/download/continuous/appimagetool-${APPIMAGE_ARCH}.AppImage" \
      -o /usr/local/bin/appimagetool && \
    chmod 755 /usr/local/bin/appimagetool

# -- Copy project source -------------------------------------------------------
WORKDIR /build

# Copy dependency manifests first for better Docker layer caching
COPY Cargo.toml Cargo.lock ./
COPY rust-toolchain.toml ./

# Copy all crate sources
COPY crates/ crates/
COPY config/ config/
COPY skills/ skills/
COPY packaging/ packaging/
COPY scripts/ scripts/
COPY README.md .

# -- Build entrypoint ----------------------------------------------------------
CMD ["./scripts/build-release.sh", "gui"]
