pkgname=y-agent-gui
pkgver=@VERSION@
pkgrel=@PKGREL@
pkgdesc='Desktop GUI for y-agent'
arch=('x86_64')
url='https://github.com/gorgias/y-agent'
license=('MIT')
depends=('webkit2gtk-4.1' 'openssl' 'hicolor-icon-theme')
source=(
  'y-gui-bin'
  'y-gui-wrapper'
  'y-agent.desktop'
  '32x32.png'
  '128x128.png'
  '128x128@2x.png'
  'skills.tar'
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

package() {
  install -d "$pkgdir/usr/lib/y-gui"
  install -Dm755 y-gui-bin "$pkgdir/usr/lib/y-gui/y-gui"
  install -Dm755 y-gui-wrapper "$pkgdir/usr/bin/y-gui"
  bsdtar -xf skills.tar -C "$pkgdir/usr/lib/y-gui"

  install -Dm644 y-agent.desktop \
    "$pkgdir/usr/share/applications/y-agent.desktop"
  install -Dm644 32x32.png \
    "$pkgdir/usr/share/icons/hicolor/32x32/apps/y-agent.png"
  install -Dm644 128x128.png \
    "$pkgdir/usr/share/icons/hicolor/128x128/apps/y-agent.png"
  install -Dm644 128x128@2x.png \
    "$pkgdir/usr/share/icons/hicolor/256x256/apps/y-agent.png"
}
