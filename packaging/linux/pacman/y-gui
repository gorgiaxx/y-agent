#!/usr/bin/env bash
set -euo pipefail

# DMA-BUF compositing can crash when the host GPU driver/mesa differs from
# build-time. Safe to disable unconditionally for a packaged app.
export WEBKIT_DISABLE_DMABUF_RENDERER="${WEBKIT_DISABLE_DMABUF_RENDERER:-1}"

# Match the AppImage launcher behaviour on Wayland so the pacman package
# takes the same conservative WebKitGTK path by default.
if [[ "${XDG_SESSION_TYPE:-}" == "wayland" || -n "${WAYLAND_DISPLAY:-}" ]]; then
  export GDK_BACKEND="${GDK_BACKEND:-x11}"
  export WEBKIT_DISABLE_COMPOSITING_MODE="${WEBKIT_DISABLE_COMPOSITING_MODE:-1}"
  export LIBGL_ALWAYS_SOFTWARE="${LIBGL_ALWAYS_SOFTWARE:-1}"
fi

exec /usr/lib/y-gui/y-gui "$@"
